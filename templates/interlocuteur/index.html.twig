{% extends 'base.html.twig' %}

{% block title %}Interlocuteur index{% endblock %}

{% block body %}
    <h1>Interlocuteur index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Username</th>
                <th>Role</th>
                <th>Nom</th>
                <th>Prenom</th>
                <th>Mail</th>
                <th>Portable</th>
                <th>Statut</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for interlocuteur in interlocuteurs %}
            <tr>
                <td>{{ interlocuteur.id }}</td>
                <td>{{ interlocuteur.username }}</td>
                <td>{{ interlocuteur.role }}</td>
                <td>{{ interlocuteur.nom }}</td>
                <td>{{ interlocuteur.prenom }}</td>
                <td>{{ interlocuteur.mail }}</td>
                <td>{{ interlocuteur.portable }}</td>
                <td>{{ interlocuteur.statut }}</td>
                <td>
                    <a href="{{ path('app_interlocuteur_show', {'id': interlocuteur.id}) }}">show</a>
                    <a href="{{ path('app_interlocuteur_edit', {'id': interlocuteur.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="9">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_interlocuteur_new') }}">Create new</a>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}
    {% if currentType == 'pending' %}
        Leads en attente
    {% else %}
        Leads fermés
    {% endif %}
    - LManager
{% endblock %}

{% block stylesheets %}
    <style>
        .sortable {
            user-select: none;
            position: relative;
            padding-right: 20px;
        }
        .sortable a {
            color: inherit;
            text-decoration: none;
            display: block;
        }
        .sortable a:hover {
            background: rgba(158, 0, 84, 0.05);
        }
        .sort-icon {
            position: absolute;
            right: 5px;
            font-size: 10px;
            color: #999;
        }
        .sort-icon.active {
            color: #9e0054;
        }
        .team-section {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
        }
        .team-badge {
            display: inline-block;
            background: #9e0054;
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            margin-right: 5px;
            margin-bottom: 5px;
        }
        .filter-section {
            background: #fff;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="leads-page">
    <div class="page-header">
        <div class="header-left">
            <h1>
                {% if currentType == 'pending' %}
                    Leads en attentes
                {% else %}
                    Leads fermés
                {% endif %}
                <span class="lead-count">{{ leads|length }} leads</span>
            </h1>
        </div>
    </div>

    {# --- SECTION CDV : AFFICHAGE DE L'ÉQUIPE --- #}
    {% if isCDV and teamOrMe == 'team' %}
        <div class="team-section">
            <h5 style="color: #666; font-size: 0.9rem; text-transform: uppercase; margin-bottom: 10px;">
                🎯 Équipe supervisée
            </h5>
            <div class="team-list">
                {% for membre in teamMembres %}
                    <span class="team-badge">
                        {{ membre.NOM }} <small style="opacity: 0.8;">({{ membre.CODE }})</small>
                    </span>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# --- FILTRE PAR COMMERCIAL (pour CDV et ATC) --- #}
    {% if (isCDV and teamOrMe in ['team', 'all']) or isATC %}
        <div class="filter-section">
            <h5 style="color: #666; font-size: 0.9rem; text-transform: uppercase; margin-bottom: 15px;">
                🔍 Filtrer par commercial
            </h5>
            <form method="get" style="display: flex; gap: 15px; align-items: end;">
                {# IMPORTANT : Préserver tous les paramètres existants #}
                <input type="hidden" name="type" value="{{ currentType }}">
                <input type="hidden" name="teamOrMe" value="{{ teamOrMe }}">
                
                <div style="flex: 1;">
                    <label for="filterCommercial" style="display: block; margin-bottom: 8px; font-weight: 500; color: #495057;">
                        Commercial :
                    </label>
                    <select name="filterCommercial" id="filterCommercial" onchange="this.form.submit()" style="width: 100%; padding: 10px 12px; border: 1px solid #ced4da; border-radius: 6px; font-size: 0.9rem;">
                        {% if isATC %}
                            {# ATC voit tous les commerciaux #}
                            <option value="all" {% if not filterCommercial or filterCommercial == 'all' %}selected{% endif %}>
                                Tous les commerciaux
                            </option>
                            {% for code, nom in commerciauxDisponibles %}
                                <option value="{{ code }}" {% if filterCommercial == code %}selected{% endif %}>
                                    {{ nom }} ({{ code }})
                                </option>
                            {% endfor %}
                        {% elseif isCDV %}
                            {# CDV voit son équipe + lui-même #}
                            <option value="all" {% if not filterCommercial or filterCommercial == 'all' %}selected{% endif %}>
                                Toute l'équipe (moi inclus)
                            </option>
                            <option value="{{ app.user.extraFields.interlocuteur }}" {% if filterCommercial == app.user.extraFields.interlocuteur %}selected{% endif %}>
                                Moi
                            </option>
                            
                            {# Membres de l'équipe (sans le CDV) #}
                            {% for membre in teamMembres %}
                                {% if membre.CODE != app.user.extraFields.interlocuteur %}
                                    <option value="{{ membre.CODE }}" {% if filterCommercial == membre.CODE %}selected{% endif %}>
                                        {{ membre.NOM }} ({{ membre.CODE }})
                                    </option>
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    </select>
                </div>
                
                {% if filterCommercial and filterCommercial != 'all' %}
                    <a href="{{ path('app_lead_index', {'type': currentType, 'teamOrMe': teamOrMe}) }}" 
                    style="padding: 10px 20px; background-color: #6c757d; color: white; border-radius: 6px; text-decoration: none; font-size: 0.9rem; display: inline-block;">
                        Réinitialiser
                    </a>
                {% endif %}
            </form>
        </div>
    {% endif %}

    <div class="table-container">
        <table class="leads-table">
            <thead>
                <tr>
                    <th>NOM</th>
                    <th>PRÉNOM</th>
                    {% if isCDV or isATC %}
                        <th>COMMERCIAL</th>
                    {% endif %}
                    <th class="sortable">
                        <a href="{{ path('app_lead_index', {'type': currentType, 'teamOrMe': teamOrMe, 'filterCommercial': filterCommercial, 'sort': 'dept', 'order': (app.request.get('sort') == 'dept' and app.request.get('order') == 'asc') ? 'desc' : 'asc'}) }}">
                            DPT
                            {% if app.request.get('sort') == 'dept' %}
                                <span class="sort-icon active">{{ app.request.get('order') == 'asc' ? '↑' : '↓' }}</span>
                            {% else %}
                                <span class="sort-icon">⇅</span>
                            {% endif %}
                        </a>
                    </th>
                    <th class="sortable">
                        <a href="{{ path('app_lead_index', {'type': currentType, 'teamOrMe': teamOrMe, 'filterCommercial': filterCommercial, 'sort': 'type', 'order': (app.request.get('sort') == 'type' and app.request.get('order') == 'asc') ? 'desc' : 'asc'}) }}">
                            TYPE
                            {% if app.request.get('sort') == 'type' %}
                                <span class="sort-icon active">{{ app.request.get('order') == 'asc' ? '↑' : '↓' }}</span>
                            {% else %}
                                <span class="sort-icon">⇅</span>
                            {% endif %}
                        </a>
                    </th>
                    <th class="sortable">
                        <a href="{{ path('app_lead_index', {'type': currentType, 'teamOrMe': teamOrMe, 'filterCommercial': filterCommercial, 'sort': 'date', 'order': (app.request.get('sort') == 'date' and app.request.get('order') == 'asc') ? 'desc' : 'asc'}) }}">
                            DATE CRÉATION
                            {% if app.request.get('sort') == 'date' %}
                                <span class="sort-icon active">{{ app.request.get('order') == 'asc' ? '↑' : '↓' }}</span>
                            {% else %}
                                <span class="sort-icon">⇅</span>
                            {% endif %}
                        </a>
                    </th>
                    <th>STATUT</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                {% for lead in leads %}
                    <tr>
                        <td class="fw-bold">{{ lead.nom|upper }}</td>
                        <td>{{ lead.prenom }}</td>

                        {% if isCDV or isATC %}
                            <td>
                                <span class="text-muted" style="font-size: 0.9rem;">
                                    {{ lead.commercialNom ?? 'N/A' }}
                                </span>
                            </td>
                        {% endif %}
                        
                        <td class="text-center">
                            <span class="badge-dept" style="background: #e9ecef; padding: 4px 8px; border-radius: 4px; font-weight: bold;">
                                {{ lead.adresseCP|slice(0, 2) }}
                            </span>
                        </td>

                        <td>
                            {% if lead.categoriedemandeur == 0 %}
                                Professionnel
                            {% else %}
                                Particulier
                            {% endif %}
                        </td>

                        <td>{{ lead.dateCreation ? lead.dateCreation|date('d M Y') : '-' }}</td>

                        <td>
                            {% if lead.statut == '0' %}
                                {% set statusClass = 'status-pending' %}
                                {% set statusLabel = 'Non Traité' %}
                            {% elseif lead.statut == '1' %}
                                {% set statusClass = 'status-processed' %}
                                {% set statusLabel = 'Orienté' %}
                            {% elseif lead.statut == '2' %}
                                {% set statusClass = 'status-closed' %}
                                {% set statusLabel = 'Fermé' %}
                            {% elseif lead.statut =='4' %}
                                {% set statusClass = 'status-archived' %}
                                {% set statusLabel = 'Traité Direct' %}
                            {% else %}
                                {% set statusClass = 'status-archived' %}
                                {% set statusLabel = 'Random' %}
                            {% endif %}

                            <span class="status-badge {{ statusClass }}">
                                {{ statusLabel }}
                            </span>
                        </td>

                        <td class="actions-cell">
                           <a href="{{ path('app_lead_show', { 'id': lead.id, 'type': currentType, 'teamOrMe': teamOrMe, 'filterCommercial': filterCommercial }) }}" class="action-btn view">👁</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="{{ (isCDV or isATC) ? '8' : '7' }}" class="no-data">Aucun lead trouvé</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
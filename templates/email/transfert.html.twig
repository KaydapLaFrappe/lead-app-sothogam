<!doctype html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Transfert de Lead</title>
    <link href='https://fonts.googleapis.com/css?family=Open+Sans:400,300' rel='stylesheet' type='text/css'>
    <style>
        * { box-sizing: border-box; }
        body { background: #eeeeee; font-family: 'Open Sans', sans-serif, Helvetica, Arial; margin: 0; padding: 0; }
        .container { max-width: 600px !important; margin: 20px auto; background: #ffffff; border-collapse: collapse; }
        .header { background: #3c533f; padding: 30px; text-align: center; }
        .header h1 { color: #ffffff; margin: 0; font-size: 24px; }
        .content { padding: 40px; text-align: center; color: #333333; }
        .footer { background: #2B2E34; padding: 20px; color: #ffffff; text-align: left; }
        .btn-link { 
            display: inline-block;
            background: #3c533f; 
            color: #ffffff !important; 
            padding: 15px 30px; 
            text-decoration: none; 
            font-weight: bold; 
            border-radius: 5px;
            margin: 20px 0;
            text-transform: uppercase;
        }
        .info-box { border-top: 1px solid #eeeeee; padding-top: 20px; font-size: 14px; }
    </style>
</head>
<body>
    <center>
        <table class="container" width="100%" cellpadding="0" cellspacing="0">
            <tr>
                <td class="header">
                    <h1>Nouveau Lead Transféré</h1>
                </td>
            </tr>

            <tr>
                <td class="content">
                    <p style="font-size: 20px; line-height: 1.5;">
                        Bonjour <strong>{{ user.prenom }}</strong>,
                    </p>
                    <p style="font-size: 16px;">
                        Le lead suivant vous a été confié par un collaborateur :
                    </p>
                    <div style="background: #f9f9f9; padding: 15px; border-radius: 8px; margin: 20px 0;">
                        <h2 style="color: #3c533f; margin: 0;">{{ lead.interlocuteur.prenom }}</h2>
                        <p style="margin: 5px 0;">Type : {{ lead.getStatut }}</p>
                    </div>
                    
                    <a href="http://leads-dev-vico.go/login/{{ lead.id }}" class="btn-link">Consulter le lead</a>
                    
                    <p class="info-box">
                        Connecte toi à l'application pour gérer ce lead
                    </p>
                </td>
            </tr>

            <tr>
                <td class="footer">
                    <table width="100%">
                        <tr>
                            <td width="50%" valign="top" style="padding-right: 10px;">
                                <h2 style="font-size: 16px; color: #ffffff;">AES ?</h2>
                                <p style="font-size: 12px; color: #bbbbbb;">L'application AES permet la gestion des leads et des fournitures des collaborateurs.</p>
                            </td>
                            <td width="50%" valign="top">
                                <h2 style="font-size: 16px; color: #ffffff;">Problème ?</h2>
                                <p style="font-size: 12px;">
                                    <a href="http://tickets.go/" style="color: #ffffff; text-decoration: underline;">Ouvrir un ticket support</a>
                                </p>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </center>
</body>
</html>